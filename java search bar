<script>
let timeout = null;

function searchBPID() {

    clearTimeout(timeout);

    timeout = setTimeout(function () {

        var search = document.getElementById("BPIDSearch").value;
        var bu = document.getElementById("<%= ddBU.ClientID %>").value;

        fetch("CDE_View.aspx/SearchProcess", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                bu: bu,
                search: search
            })
        })
        .then(res => res.json())
        .then(data => {

            var ddl = document.getElementById("<%= ddProcess.ClientID %>");
            ddl.innerHTML = "";

            // default option
            var opt = document.createElement("option");
            opt.text = "Select Process Ids:";
            opt.value = "";
            ddl.add(opt);

            data.d.forEach(function (row) {

                var option = document.createElement("option");
                option.text = row.Text;
                option.value = row.Value;

                ddl.add(option);
            });

        });

    }, 300); // prevents too many SQL calls
}
</script>
